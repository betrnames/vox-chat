# SpaceXAI / xAI — https://console.x.ai
# Required for live AI Receptionist (POST /api/receptionist)
XAI_API_KEY=
# Optional model override (default: grok-3-mini)
# XAI_MODEL=grok-3-mini

# Lead email (defaults to existing Formspree form if unset)
FORMSPREE_ENDPOINT=https://formspree.io/f/mwvdpgay

# Optional: Google Sheet via free Apps Script web app (doPost)
LEAD_SHEET_WEBHOOK_URL=

# Automated Google Sheet (preferred) — run: node scripts/setup-google-leads.mjs you@gmail.com
# after saving google-service-account.json in project root
GOOGLE_SHEET_ID=
GOOGLE_SHEET_RANGE=Leads!A:K
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
